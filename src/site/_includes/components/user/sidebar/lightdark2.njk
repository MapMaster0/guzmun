
<aside id="floating-control">
    <span id="theme-switch">
        <i class="svg-icon light" icon-name="sun" aria-hidden="true"></i>
        <i class="svg-icon dark" icon-name="moon" aria-hidden="true"></i>
    </span>
</aside>

<script>
    function setThemeIcon(theme) {
        const el = document.getElementById('theme-switch');
        el.classList.remove('light', 'dark');
        el.classList.add(theme);
    }

    function setTheme(theme) {
        setThemeIcon(theme);
        if (theme === 'dark') {
            document.body.classList.add('theme-dark');
            document.body.classList.remove('theme-light');
        } else {
            document.body.classList.add('theme-light');
            document.body.classList.remove('theme-dark');
        }
        window.theme = theme;
        window.localStorage.setItem('site-theme', theme);
    }

    // Load saved theme, default to light
    let savedTheme = window.localStorage.getItem('site-theme');
    if (savedTheme !== 'dark' && savedTheme !== 'light') savedTheme = 'light';
    setTheme(savedTheme);

    // Toggle on click
    document.getElementById('theme-switch').addEventListener('click', function () {
        setTheme(window.theme === 'dark' ? 'light' : 'dark');
    });
</script>
